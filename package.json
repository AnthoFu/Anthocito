{
    "dependencies": {
        "discord.js": "^14.14.1",
        "dotenv": "^16.4.5",
        "express": "^5.2.1",
        "mongoose": "^9.2.4",
        "node-fetch": "^2.7.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.4.0",
        "@types/node-fetch": "^2.6.13",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "eslint": "^8.57.1",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.32.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.6",
        "prettier": "^3.6.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "prepare": "husky",
        "start": "node dist/index.js",
        "dev": "ts-node index.ts",
        "build": "tsc",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "lint-staged": {
        "*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": "prettier --write"
    }
}
